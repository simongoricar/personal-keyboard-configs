{
  "name": "Gruvbox (dark)",
  "backgroundColor": "#a89984",
  "rules": [
    {
      "name": "Default",
      "colors": {
        "color": "#2b2928",
        "defaultTextColor": "#ebdbb2"
      }
    },
    {
      "name": "Modifiers",
      "matchers": "width > 1 or height > 1",
      "colors": {
        "color": "#222222",
        "defaultTextColor": "#ebdbb2"
      }
    },
    {
      "name": "Space",
      "matchers": "width >= 4",
      "colors": {
        "color": "#2b2928",
        "defaultTextColor": "#ebdbb2"
      }
    },
    {
      "name": "Decal Text",
      "matchers": "decal",
      "colors": {
        "defaultTextColor": "#000000"
      }
    }
  ]
}
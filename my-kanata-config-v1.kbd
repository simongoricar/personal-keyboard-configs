;; )

(deflayer l_base
    @th_esc
    _   _ _ _ _ _ _ _ _ _ _ _ _  _
    _   _ _ _ _ _ _ _ _ _ _ _ _   _
    esc   _ @th_s @th_d _ _ _ _ _ _ _ _ _
    _   _ _ _ _ _ _ _ _ _ _  _
    _ _ _   _   _ _ _ _
)

(deflayer l_system
    _
    _   _ _ _ _ _ _ _ _ _ _ _ _  _
    _   _ _ _ lrld _ _ _ _ _ _ _ _   _
    _   _ _ _ _ _ _ _ _ _ _ _ _
    _   _ _ @ext_vscode-launch _ _ _ _ _ _ _      _
    _ _ _   _   _ _ _ _
)

(deflayer l_programming
    _
    _   _ _ _ _ _ _ _ _ _ _ _ _  _
    _   _ _ _ _ _ _ _ @vsc_cursor_up40 _ _ _ _   _
    _   _ _ _ _ _ _ @vsc_cursor_down40 _ _ _ _ _
    _   _ _ _ _ _ _ _ _ _ _      _
    _ _ _   _   _ _ _ _
)

(deflayer l_editor-navigation
    _
    _   _ _ _ _ _ _ _ _ _ _ _ _  _
    _   _ _ _ _ _ _ _ _ _ _ _ _   _
    _   _ _ _ _ _ _ _ _ _ _ _ _
    _   _ _ _ _ _ _ _ _ @vsc_focus-folder-view _      _
    _ _ _   _   _ _ _ _
)
(deflayer l_base
    @th_esc
    _   _ _ _ _ _ _ _ _ _ _ _ @th_*  _
    _   _ _ _ _ _ _ _ _ _ _ _ @th_đ   _
    esc   _ @th_s @th_d @th_f _ _ _ _ _ _ _ _
    _   _ _ _ _ _ _ _ _ _ _  _
    _ _ _   _   _ _ _ _
)

(deflayer l_system
    _
    _   XX XX XX XX XX XX XX XX XX XX XX XX  _
    _   XX XX XX lrld XX XX XX XX XX XX XX XX   _
    _   XX XX XX XX XX XX XX XX XX XX XX XX
    _   XX XX @ext_vscode-launch XX XX XX XX XX XX XX      _
    _ _ _   _   _ _ _ _
)

(deflayer l_programming
    _
    _   XX XX XX XX XX XX XX XX XX @vsc_goto-previous-problem @vsc_goto-next-problem home  _
    _   XX esc lshft XX XX XX XX @vsc_cursor_up20 @vsc_cursor_up10 @vsc_cursor_up5 up end   _
    _   XX XX XX XX XX XX @vsc_cursor_down20 @vsc_cursor_down10 @vsc_cursor_down5 left down rght
    _   lctrl XX XX XX XX XX XX @vsc_goto-definition @vsc_focus-breadcrumbs @td_vsc-preview-or-open-docs      _
    _ _ _   _   _ _ _ _
)

(deflayer l_editor-navigation
    _
    _   _ _ _ _ _ _ _ @vsc_toggle-fullscreen @vsc_toggle-centered-layout @vsc_create-new-terminal @vsc_reopen-closed-editor @vsc_close-active-editor  _
    _   _ _ _ _ _ _ _ _ _ _ @vsc_previous-ET-in-group @vsc_split-ET-into-right-group   _
    _   _ _ _ _ _ _ _ _ @vsc_focus-active-text-editor @vsc_focus-left-ET-group @vsc_next-ET-in-group @vsc_focus-right-ET-group
    _   _ _ _ @th_v _ _ _ @vsc_focus-terminal @vsc_focus-folder-view @vsc_toggle-maximize-editor-group      _
    _ _ _   _   _ _ _ _
)

(deflayer l_editor-navigation_moves
    _
    _   _ _ _ _ _ _ _ _ _ _ _ _  _
    _   _ _ _ _ _ _ _ _ _ _ @vsc_move-terminal-to-editor _   _
    _   _ _ _ _ _ _ _ _ _ @vsc_move-editor-into-left-group @vsc_move-terminal-to-panel @vsc_move-editor-into-right-group
    _   _ _ _ _ _ _ _ @vsc_toggle-terminal-visibility @vsc_toggle-right-sidebar-visibility _      _
    _ _ _   _   _ _ _ _
)

(deflayer l_symbols
    _
    _   XX XX @sym_at @sym_dollar XX XX XX XX XX left XX XX  _
    _   @sym_grave-accent @sym_hashtag @sym_mult @sym_fslash @sym_and @sym_lt @sym_minus @sym_gt @sym_colon rght XX XX   _
    _   XX XX @sym_bslash @sym_eq @sym_lsb @sym_not @sym_rpar @sym_lpar @sym_scolon @sym_plus @sym_undsc XX
    _   @sym_pipe @sym_mod @sym_dquot @sym_squot @sym_rsb @sym_rcurb @sym_lcurb @sym_comma @sym_dot @sym_minus      _
    _ _ _   _   _ _ _ _
)
